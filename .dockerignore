# Keep dev runtime-state out of the image so COPY . . can't bake stale local
# caches/history over the server's. These live on the poe-data volume instead.
.*.json
.poe-oauth*.json
.playwright-cli/
node_modules/
*.env
# Never bake the git history into the image (COPY . . would copy it all).
.git/
# VM-local auto-deploy state (last successfully deployed sha).
.last-deployed-sha
