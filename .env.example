# Copy to .env on the VM (next to docker-compose.yml) and fill in.
# These are NordVPN SERVICE credentials, NOT your account email/password.
# Get them: Nord dashboard → NordVPN → "Set up NordVPN manually" → Service credentials.
NORD_USER=your-service-username
NORD_PASS=your-service-password
# VPN exit country at BOOT — keep it in the EU so latency to the EU realm stays low.
# You can switch it live from the app's top-bar selector (no redeploy); a
# `docker compose up` recreate resets to this value.
NORD_COUNTRY=Netherlands
# Gear Finder (optional): URL of pob-agent.js running on the Main PC (where Path
# of Building + LuaJIT are installed) so the VM can do headless build-weighting.
# Use the PC's Tailscale IP. Leave unset/empty to disable (tool shows "Stat-only").
POB_BRIDGE_URL=http://REDACTED-TAILNET-IP-B:17778
# Gear Finder (optional): a logged-in pathofexile.com POESESSID cookie. Unlocks the
# build-weighted trade sort so "Rank by real DPS" fetches the BEST candidates for your
# build instead of a price spread. USE A THROWAWAY ACCOUNT — this is full account access.
# Grab it: log into pathofexile.com → F12 → Application/Storage → Cookies → POESESSID.
# Leave empty for the price-spread fallback. Rotates on logout — refresh occasionally.
POESESSID=
